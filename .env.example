# ─────────────────────────────────────────────────────────────────────────────
# Cloudlink Web (Next.js) — Environment Variables
# Copy this file to .env.local for local dev.
# In production (Vercel), set these in the Vercel project environment settings.
# NEVER commit your actual .env.local file — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API ───────────────────────────────────────────────────────────────
# URL of the deployed cloudlink-agents Railway service.
# Used by both server-side API routes and client-side components.
NEXT_PUBLIC_API_URL=https://cloudlink-agents-production.up.railway.app

# ── Authentication (Clerk) ────────────────────────────────────────────────────
# Found at: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Stripe (billing) ─────────────────────────────────────────────────────────
# Found at: https://dashboard.stripe.com → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs for subscription plans — found in Stripe Dashboard → Products
# Create two products (Starter and Growth) and paste their Price IDs here.
STRIPE_STARTER_PRICE_ID=price_
STRIPE_GROWTH_PRICE_ID=price_

# Metered billing price for performance model (15% of savings).
# Create a product in Stripe with usage-based billing, unit_amount=1 (1 cent per unit).
# We report usage in cents (e.g. $150 fee = 15000 units).
STRIPE_METERED_PRICE_ID=price_
# Event name set in your Stripe Meter (must match exactly)
STRIPE_METER_EVENT_NAME=cloudlink_savings_fee

# ── Performance billing ───────────────────────────────────────────────────────
# Secret used to authenticate the month-end billing cron job.
# Set this to a long random string and include it in the Authorization header
# when calling POST /api/billing/month-end.
CRON_SECRET=

# ── Analytics (optional) ──────────────────────────────────────────────────────
# PostHog product analytics (privacy-friendly, self-hostable)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
