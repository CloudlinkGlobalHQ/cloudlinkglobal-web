# ─────────────────────────────────────────────────────────────────────────────
# Cloudlink Web (Next.js) — Environment Variables
# Copy this file to .env.local for local dev.
# In production (Vercel), set these in the Vercel project environment settings.
# NEVER commit your actual .env.local file — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API ───────────────────────────────────────────────────────────────
# URL of the deployed cloudlink-agents Railway service.
# Used by both server-side API routes and client-side components.
NEXT_PUBLIC_API_URL=https://cloudlink-agents-production.up.railway.app

# ── Authentication (Clerk) ────────────────────────────────────────────────────
# Found at: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Stripe (billing) ─────────────────────────────────────────────────────────
# Found at: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs for subscription plans — found in Stripe Dashboard → Products
# Create two products (Starter and Growth) and paste their Price IDs here.
STRIPE_STARTER_PRICE_ID=price_
STRIPE_GROWTH_PRICE_ID=price_

# ── Analytics (optional) ──────────────────────────────────────────────────────
# PostHog product analytics (privacy-friendly, self-hostable)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
